/* WiFi credentials for the Hydra controller.
 *
 * Copy this file to main/wifi_credentials.h and edit the two strings
 * before running `idf.py build`. The real wifi_credentials.h is
 * gitignored so your password won't leak into a commit.
 *
 *   cp main/wifi_credentials.h.example main/wifi_credentials.h
 *   $EDITOR main/wifi_credentials.h
 */

#define HYDRA_WIFI_SSID  "your-ssid-here"
#define HYDRA_WIFI_PSK   "your-wpa2-password-here"

/* Optional: change the mDNS hostname (defaults to "hydra-ctrl" so the
 * web UI is reachable at http://hydra-ctrl.local/). */
/* #define HYDRA_MDNS_HOSTNAME "hydra-ctrl" */
